{
  "title": "Pull Queue Messages Example",
  "description": "Example request and response for pulling a batch of messages from a Cloudflare Queue using HTTP pull consumer.",
  "request": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/queues/{queue_id}/messages/pull",
    "headers": {
      "Authorization": "Bearer <api_token>",
      "Content-Type": "application/json"
    },
    "body": {
      "batch_size": 10,
      "visibility_timeout_ms": 30000
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
