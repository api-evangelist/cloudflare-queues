{
  "title": "Push Message to Queue Example",
  "description": "Example request and response for pushing a single message to a Cloudflare Queue.",
  "request": {
    "method": "POST",
    "url": "https://api.cloudflare.com/client/v4/accounts/{account_id}/queues/{queue_id}/messages",
    "headers": {
      "Authorization": "Bearer <api_token>",
      "Content-Type": "application/json"
    },
    "body": {
      "body": "Hello, Cloudflare Queues!",
      "content_type": "text",
      "delay_seconds": 0
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "success": true,
      "errors": [],
      "messages": [],
      "result": {
        "metadata": {
          "metrics": {
            "backlog_count": 1,
            "backlog_bytes": 26,
            "oldest_message_timestamp_ms": 1710950954154
          }
        }
      }
    }
  }
}
